{
  "expo": {
    "name": "عين - Ayeeen",
    "slug": "ayeeen",
    "version": "1.0.0",
    "scheme": "ayeeen",
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#7C3AED",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alwahdi.ayeeen",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "package": "com.alwahdi.ayeeen"
    },
    "extra": {
      "eas": {
        "projectId": "627f26b6-85d8-446e-97ff-a818a76b9669"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "alwahdi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/627f26b6-85d8-446e-97ff-a818a76b9669"
    }
  }
}
